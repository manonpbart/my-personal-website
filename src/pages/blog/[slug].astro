---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BLOG_POSTS } from '../../utils/projectConstants.js';

// One page per post — Astro builds these automatically from BLOG_POSTS,
// so adding a post to the constants file is all you ever need to do.
export function getStaticPaths() {
    return BLOG_POSTS.map(post => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
---

<BaseLayout title={`${post.title} — Manon Bart`}>
    <div class="content-section">
        <div class="back-nav">
            <a href="/blog" class="back-link">← back_to_blog</a>
        </div>

        <article class="post">
            <span class="entry-meta">{post.date}</span>
            <h1>{post.title}</h1>
            {post.paragraphs.map(paragraph => (
                <p>{paragraph}</p>
            ))}
        </article>
    </div>
</BaseLayout>

<style>
    .back-nav { margin-bottom: 2rem; }

    .back-link {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--moss);
        text-decoration: none;
    }

    .back-link:hover { color: var(--moss-deep); }

    .post { max-width: 46rem; }

    .post h1 {
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        font-weight: 700;
        margin: 0.4rem 0 1.5rem;
    }

    .post p {
        margin-bottom: 1.25rem;
        font-size: 1.05rem;
        line-height: 1.7;
    }
</style>
