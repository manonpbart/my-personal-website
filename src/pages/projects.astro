---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROJECTS, createTagBadges } from '../utils/projectConstants.js';

const projects = Object.values(PROJECTS);
---

<BaseLayout title="Projects — Manon Bart">
    <div class="content-section">
        <h2>projects</h2>
        <p class="page-intro">This page is dedicated to fun personal projects! Some more useful than others...</p>

        <div class="projects-scroll">
            {projects.map(project => (
                <a href={project.url} class="project-item">
                    {project.icon.startsWith('/') ? (
                        <img src={project.icon} alt="" class="project-icon-img" />
                    ) : (
                        <div class="project-icon">{project.icon}</div>
                    )}
                    <h3>{project.name}</h3>
                    <div class="project-tags" set:html={createTagBadges(project.tags)}></div>
                    <p class="project-description">{project.description}</p>
                </a>
            ))}

            <!-- Coming soon slot -->
            <div class="project-item project-item--empty">
                <div class="project-icon" aria-hidden="true">+</div>
                <h3>More on the way</h3>
                <p class="project-description">New experiments land here as they're built. Check back soon!</p>
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .page-intro {
        max-width: 46rem;
        color: var(--ink-soft);
    }

    .project-item--empty {
        border-style: dashed;
        background: transparent;
        cursor: default;
    }

    .project-item--empty:hover {
        transform: none;
        box-shadow: none;
        border-color: var(--line);
    }

    .project-item--empty .project-icon {
        font-family: var(--font-mono);
        color: var(--moss);
    }
</style>
