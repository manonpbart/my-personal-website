---
import BaseLayout from '../layouts/BaseLayout.astro';
import { RESEARCH_PROJECTS, createTagBadges, createSlug } from '../utils/projectConstants.js';

const researchProjects = Object.values(RESEARCH_PROJECTS);

// Every unique keyword across all research projects, for the filter sidebar
const keywords = [...new Set(researchProjects.flatMap(p => p.tags))];
---

<BaseLayout title="Research — Manon Bart">
    <div class="content-section">
        <h2>research</h2>
        <p class="page-intro">This page is dedicated to my research interests. Here you will find specific projects in optical communication, optical computing and neural networks, and quantum information processing. Most of these projects leverage machine learning in some fashion.</p>

        <div class="research-layout">
            <!-- Keyword filter -->
            <aside class="keyword-panel">
                <span class="eyebrow">filter_by_keyword</span>
                <div class="keyword-list" role="group" aria-label="Filter research by keyword">
                    <button class="keyword-btn" data-keyword="all" aria-pressed="true">all</button>
                    {keywords.map(keyword => (
                        <button class="keyword-btn" data-keyword={createSlug(keyword)} aria-pressed="false">
                            {keyword}
                        </button>
                    ))}
                </div>
            </aside>

            <!-- Research cards -->
            <div>
                <div class="projects-scroll" id="research-grid">
                    {researchProjects.map(project => (
                        <a href={`/research/${project.slug}`}
                           class="project-item"
                           data-tags={project.tags.map(createSlug).join(' ')}>
                            {project.icon.startsWith('/') ? (
                                <img src={project.icon} alt="" class="project-icon-img" />
                            ) : (
                                <div class="project-icon">{project.icon}</div>
                            )}
                            <h3>{project.name}</h3>
                            <div class="project-tags" set:html={createTagBadges(project.tags)}></div>
                            <p class="project-description">{project.description}</p>
                            <span class="read-more">read_more →</span>
                        </a>
                    ))}
                </div>
                <p class="no-results" id="no-results" hidden>no_results_for_this_keyword :(</p>
            </div>
        </div>
    </div>

    <script>
        const buttons = document.querySelectorAll('.keyword-btn');
        const cards = document.querySelectorAll('#research-grid .project-item');
        const noResults = document.getElementById('no-results');

        buttons.forEach(button => {
            button.addEventListener('click', () => {
                const keyword = button.dataset.keyword;

                // One active keyword at a time
                buttons.forEach(b => b.setAttribute('aria-pressed', String(b === button)));

                let visible = 0;
                cards.forEach(card => {
                    const tags = (card.dataset.tags || '').split(' ');
                    const show = keyword === 'all' || tags.includes(keyword);
                    card.hidden = !show;
                    if (show) visible++;
                });

                if (noResults) noResults.hidden = visible > 0;
            });
        });
    </script>
</BaseLayout>

<style>
    .page-intro {
        max-width: 46rem;
        color: var(--ink-soft);
    }

    .read-more {
        display: inline-block;
        margin-top: 0.9rem;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--moss);
    }

    .project-item:hover .read-more { color: var(--moss-deep); }
</style>
